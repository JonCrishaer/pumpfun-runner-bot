# Pump.fun Trading Bot - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# CORE SETTINGS
# ============================================
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# ============================================
# SOLANA RPC CONFIGURATION
# ============================================
# Mainnet RPC endpoints
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Alternative RPC providers (recommended for production)
# SOLANA_RPC_URL=https://rpc.helius.xyz/?api-key=YOUR_HELIUS_KEY
# SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# SOLANA_RPC_URL=https://api.quicknode.com/solana/YOUR_QUICKNODE_KEY

# ============================================
# WALLET CONFIGURATION
# ============================================
# WARNING: Keep your private key secure!
WALLET_PRIVATE_KEY=your_base58_encoded_private_key_here
WALLET_ADDRESS=your_wallet_public_key_here

# ============================================
# TRADING SETTINGS
# ============================================
TRADING_ENABLED=false
MAX_POSITION_SIZE_SOL=1.0
STOP_LOSS_PERCENT=15
TAKE_PROFIT_PERCENT=50
MAX_SLIPPAGE_PERCENT=2.0

# Risk Management
MAX_DAILY_LOSS_SOL=5.0
MAX_POSITIONS=10
MIN_LIQUIDITY_USD=10000
MAX_OPEN_TRADES_PER_HOUR=5

# ============================================
# API SERVER SETTINGS
# ============================================
API_HOST=0.0.0.0
API_PORT=8080
API_KEY=your_secure_api_key_here
API_RATE_LIMIT=100

# ============================================
# DATABASE CONFIGURATION
# ============================================
# SQLite (default for development)
DATABASE_URL=sqlite:///data/trader.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://trader:password@localhost:5432/pumpfun_trader
DB_USER=trader
DB_PASSWORD=traderpass
DB_NAME=pumpfun_trader

# Redis cache
REDIS_URL=redis://localhost:6379/0

# ============================================
# TELEGRAM NOTIFICATIONS
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_IDS=-1001234567890,-1009876543210

# ============================================
# DISCORD NOTIFICATIONS
# ============================================
DISCORD_WEBHOOK_URLS=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN

# ============================================
# EMAIL NOTIFICATIONS
# ============================================
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=alert_recipient@example.com

# ============================================
# SMS NOTIFICATIONS (TWILIO)
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBERS=+0987654321,+1122334455

# ============================================
# MONITORING & ALERTING
# ============================================
# Health check thresholds
MAX_CPU_PERCENT=80
MAX_MEMORY_PERCENT=85
MAX_DISK_PERCENT=90
MAX_SIGNAL_AGE_SECONDS=300

# Alert intervals
MIN_ALERT_INTERVAL_SECONDS=60
ALERT_ON_ERRORS=true
ALERT_ON_CRITICAL=true

# ============================================
# GRAFANA SETTINGS
# ============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_URL=http://localhost:3000

# ============================================
# WATCHTOWER SETTINGS (AUTO-UPDATE)
# ============================================
WATCHTOWER_EMAIL_FROM=watchtower@example.com
WATCHTOWER_EMAIL_TO=admin@example.com
WATCHTOWER_EMAIL_SERVER=smtp.gmail.com
WATCHTOWER_EMAIL_PORT=587
WATCHTOWER_EMAIL_USER=your_email@gmail.com
WATCHTOWER_EMAIL_PASSWORD=your_password

# ============================================
# PUMPFUN SPECIFIC SETTINGS
# ============================================
PUMPFUN_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
BONDING_CURVE_ADDRESS=TSLvdd1pWpHVjahSpsvCXUbgwsL3JAcvok1KtgncwGM

# ============================================
# BITQUERY CONFIGURATION (Real-time bonding curve)
# ============================================
BITQUERY_API_KEY=your_bitquery_api_key_here
BITQUERY_ENABLED=true
BITQUERY_WS_URL=wss://streaming.bitquery.io/graphql
BITQUERY_REST_URL=https://graphql.bitquery.io

# ============================================
# RUNNER DETECTOR CONFIGURATION
# ============================================
# Runner detection thresholds
RUNNER_ENABLED=true
RUNNER_MIN_PROGRESS=0.85
RUNNER_MAX_PROGRESS=0.98
RUNNER_MIN_HOLDERS=50
RUNNER_MIN_MOMENTUM_VELOCITY=0.01
RUNNER_MIN_VOLUME_ACCELERATION=2.0
RUNNER_SCORE_THRESHOLD=0.70
RUNNER_CLEANUP_INTERVAL_SEC=300

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_AUTO_BUY=true
ENABLE_AUTO_SELL=true
ENABLE_PAPER_TRADING=false
ENABLE_ADVANCED_METRICS=true
